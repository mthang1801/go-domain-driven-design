{"content_type":"tech","visual_kind":"workflow_map","title":"Triggers & PL/pgSQL","subtitle":"BEFORE → row operation → AFTER — trigger execution timeline","eyebrow":"PostgreSQL Fundamental","palette_overrides":{"background":"#F0F4F8","text":"#0C1220","muted":"#475569","accent":"#0369A1","accent_soft":"#E0F2FE","panel":"#FFFFFF","border":"#7DD3FC"},"panels":[{"heading":"BEFORE Trigger","tag":"01","bullets":["Fires before row modification","Can modify NEW values","Can cancel operation (RETURN NULL)","Use: validation, default fill"]},{"heading":"Row Operation","tag":"02","bullets":["INSERT, UPDATE, DELETE","Actual data modification","Row-level or statement-level","NEW and OLD available"]},{"heading":"AFTER Trigger","tag":"03","bullets":["Fires after row modification","Row already committed to WAL","Cannot modify the row","Use: audit log, notification"]},{"heading":"Error Handling","tag":"PL/pgSQL","bullets":["EXCEPTION block catches errors","RAISE for custom errors","FOUND flag after queries","RETURN NEW / OLD / NULL"]}],"footer":"BEFORE for validation, AFTER for side effects. Never put heavy logic in triggers — use application layer.","output_path":"assets/sql/postgresql/fundamental/images/10-triggers-plpgsql-workflow.png"}
