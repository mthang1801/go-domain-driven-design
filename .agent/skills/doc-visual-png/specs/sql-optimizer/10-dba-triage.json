    {
      "heading": "Disk Full / Growth",
      "tag": "Symptom",
      "bullets": [
        "Check: table bloat (dead tuples)",
        "Check: WAL retention",
        "Module: VACUUM & WAL"
      ]
    },
    {
      "heading": "Connection Exhaustion",
      "tag": "Symptom",
      "bullets": [
        "Check: pg_stat_activity count",
        "Check: idle in transaction",
        "Module: Connection Pooling"
      ]
    },
    {
      "heading": "Replication Lag",
      "tag": "Symptom",
      "bullets": [
        "Check: pg_stat_replication",
        "Check: WAL sender / receiver",
        "Module: Streaming HA"
      ]
    },
    {
      "heading": "Slow Queries",
      "tag": "Symptom",
      "bullets": [
        "Check: pg_stat_statements",
        "Check: missing indexes",
        "Module: EXPLAIN + Indexing"
      ]
    },
    {
      "heading": "Data Corruption",
      "tag": "Critical",
      "bullets": [
        "Check: pg_catalog consistency",
        "Check: checksum failures",
        "Module: Backup & PITR"
      ]
    }
  ],
  "footer": "Start with pg_stat_activity and pg_stat_statements — they cover 80% of production triage.",
