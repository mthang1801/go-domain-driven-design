  "panels": [
    {
      "heading": "B-tree",
      "tag": "Default",
      "bullets": [
        "Equality and range queries",
        "ORDER BY, UNIQUE constraints",
        "Most common — use unless reason not to",
        "Supports: =, <, >, BETWEEN, IN"
      ]
    },
    {
      "heading": "GIN",
      "tag": "Composite",
      "bullets": [
        "JSONB containment (@>)",
        "Array overlap (&&), full-text (@@)",
        "Slower writes, faster reads",
        "Multi-key per row"
      ]
    },
    {
      "heading": "GiST",
      "tag": "Spatial",
      "bullets": [
        "Geometric, range, full-text",
        "Exclusion constraints (&&)",
        "PostGIS operations",
        "Lossy — recheck needed"
      ]
    },
    {
      "heading": "BRIN",
      "tag": "Large Table",
      "bullets": [
        "Block range summaries",
        "Time-series, append-only data",
        "Tiny index, huge table",
        "Requires physical correlation"
      ]
    },
    {
      "heading": "Hash",
      "tag": "Equality",
      "bullets": [
        "Equality-only lookups",
        "Smaller than B-tree for = queries",
        "No range, no ORDER BY",
        "WAL-logged since PG 10"
      ]
    },
    {
      "heading": "Partial / Expression",
      "tag": "Advanced",
      "bullets": [
        "WHERE clause filters subset",
        "Function-based: LOWER(email)",
        "Smaller, more targeted",
        "Combine with any index type"
      ]
    }
  ],
  "footer": "Default to B-tree. Switch only when query pattern demands GIN/GiST/BRIN.",
