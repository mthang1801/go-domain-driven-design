      ]
    },
    {
      "heading": "vs Decorator",
      "tag": "Distinction",
      "bullets": [
        "Decorator: same interface, adds behavior",
        "Adapter: different interface, translates"
      ]
    },
    {
      "heading": "vs Facade",
      "tag": "Distinction",
      "bullets": [
        "Facade: simplifies subsystem, new API",
        "Adapter: bridges 1:1 interface mismatch"
      ]
    }
  ],
  "footer": "Adapter = interface translator. If you're adding behavior, that's Decorator. If you're simplifying, that's Facade.",
