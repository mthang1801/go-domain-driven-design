      "heading": "Range Partition",
      "tag": "Time-Series",
      "bullets": [
        "Partition by date/timestamp range",
        "Best for: logs, events, time-series",
        "Enables partition pruning on WHERE",
        "Easy to drop old partitions"
      ]
